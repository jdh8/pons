# Generated by Cargo
# will have compiled files and executables
/target/

# Off-crate trainer (its own workspace); ignore its build output.
/trainer/target/

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# More information here https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
Cargo.lock
# ...but keep the off-crate trainer's lockfile so training runs reproduce (the
# negation must follow the broad rule above to take effect).
!/trainer/Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# VS Code config
/.vscode/

# Claude and AI context
/.claude/*
!/.claude/skills/